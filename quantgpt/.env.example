# ───────────────────────── QuantGPT environment ─────────────────────────
# Copy to .env and edit. All values are required unless marked optional.

# ── App ──
QUANTGPT_ENV=development
QUANTGPT_LOG_LEVEL=INFO
QUANTGPT_PUBLIC_URL=http://localhost:3000
QUANTGPT_API_URL=http://localhost:8000

# ── Backend ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1
BACKEND_CORS_ORIGINS=http://localhost:3000

# ── Auth ──
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
QUANTGPT_JWT_SECRET=change-me-please-generate-a-48-byte-secret
QUANTGPT_JWT_ALGORITHM=HS256
QUANTGPT_JWT_ACCESS_TTL_MINUTES=30
QUANTGPT_JWT_REFRESH_TTL_DAYS=7

# ── Initial admin (seeded on first migrate) ──
QUANTGPT_ADMIN_EMAIL=admin@quantgpt.dev
QUANTGPT_ADMIN_PASSWORD=ChangeMe123!

# ── PostgreSQL ──
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=quantgpt
POSTGRES_USER=quantgpt
POSTGRES_PASSWORD=quantgpt_dev_password
# Used by SQLAlchemy (built from the above in settings.py)
DATABASE_URL=postgresql+psycopg://quantgpt:quantgpt_dev_password@postgres:5432/quantgpt

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ── OpenAlgo Integration (external, unmodified) ──
OPENALGO_BASE_URL=http://openalgo:5000
OPENALGO_API_KEY=
OPENALGO_WEBSOCKET_URL=ws://openalgo:8765
OPENALGO_MCP_URL=
OPENALGO_REQUEST_TIMEOUT_SECONDS=10
OPENALGO_MAX_RETRIES=3

# ── Frontend (Next.js, NEXT_PUBLIC_* baked at build time) ──
NEXT_PUBLIC_API_URL=http://localhost:8000
